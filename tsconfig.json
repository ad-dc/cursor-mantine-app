{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "app/layout.tsx",
    "app/page.tsx",
    "components/HeaderBar.tsx",
    "components/MainLayout.tsx",
    "components/MantineThemeProvider.tsx",
    "components/SidebarNav.tsx",
    "components/SidebarNavLink.tsx",
    "components/DesignSystem/Buttons/ActionIcon.tsx",
    "components/DesignSystem/Buttons/Button.tsx",
    "components/DesignSystem/DataDisplay/Alert.tsx",
    "components/DesignSystem/DataDisplay/Badge.tsx",
    "components/DesignSystem/DataDisplay/Card.tsx",
    "components/DesignSystem/DataDisplay/ThemeIcon.tsx",
    "components/DesignSystem/Typography/Text.tsx",
    "components/DesignSystem/Typography/Title.tsx",
    "components/DesignSystem/Layout/Box.tsx",
    "components/DesignSystem/Layout/Grid.tsx",
    "components/DesignSystem/Layout/Inline.tsx",
    "components/DesignSystem/Layout/Stack.tsx",
    "components/DesignSystem/Navigation/Breadcrumb.tsx",
    "components/DesignSystem/ComplexComponents/KeyInsights/**/*.ts",
    "components/DesignSystem/ComplexComponents/KeyInsights/**/*.tsx",
    "components/DesignSystem/ComplexComponents/NameValue/**/*.ts",
    "components/DesignSystem/ComplexComponents/NameValue/**/*.tsx",
    "components/DesignSystem/ComplexComponents/PageContentHeader/**/*.ts",
    "components/DesignSystem/ComplexComponents/PageContentHeader/**/*.tsx",
    "components/DesignSystem/config.ts",
    "styles/**/*.ts",
    "next.config.ts",
    "vitest.shims.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "storybook-static",
    ".storybook",
    "tools",
    "app/badge-test",
    "**/*.stories.*",
    "**/*.figma.*"
  ]
}
