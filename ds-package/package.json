{
  "name": "@appdirect/ds-prototype-kit",
  "version": "0.2.0",
  "description": "AppDirect Design System components for prototyping. Wraps Mantine v9 with standardized props, variants, and tokens.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "node scripts/build.js",
    "tarball": "npm run build && npm pack",
    "verify:package": "npm pack --dry-run --ignore-scripts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mantine/dropzone": "^9.0.1",
    "@remixicon/react": "^4.6.0",
    "@tabler/icons-react": "^3.33.0"
  },
  "peerDependencies": {
    "@mantine/core": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ad-dc/cursor-mantine-app.git"
  },
  "license": "UNLICENSED"
}
