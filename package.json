{
  "name": "cursor-mantine-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app/layout.tsx app/page.tsx components/HeaderBar.tsx components/MainLayout.tsx components/MantineThemeProvider.tsx components/SidebarNav.tsx components/SidebarNavLink.tsx next.config.ts --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:all": "tsc -p tsconfig.all.json --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "create-page": "node tools/create-page.js",
    "export-pages": "node tools/export-page.js",
    "figma:parse": "figma connect parse --skip-update-check --config figma.config.json --dir components/DesignSystem --exit-on-unreadable-files -t \"$(grep -E '^FIGMA_ACCESS_TOKEN=' .env.local | cut -d= -f2-)\"",
    "figma:publish": "figma connect publish --skip-update-check --config figma.config.json -t \"$(grep -E '^FIGMA_ACCESS_TOKEN=' .env.local | cut -d= -f2-)\"",
    "figma:unpublish": "figma connect unpublish --skip-update-check --config figma.config.json -t \"$(grep -E '^FIGMA_ACCESS_TOKEN=' .env.local | cut -d= -f2-)\""
  },
  "dependencies": {
    "@mantine/core": "^9.0.1",
    "@mantine/dates": "^9.0.1",
    "@mantine/dropzone": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "@mantine/notifications": "^9.0.1",
    "@mantinex/mantine-logo": "^2.0.0",
    "@remixicon/react": "^4.6.0",
    "@tabler/icons-react": "^3.33.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "mantine-react-table-open": "^9.0.3",
    "next": "^16.1.6",
    "open-color": "^1.9.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remixicon": "^4.6.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/eslintrc": "^3",
    "@figma/code-connect": "^1.4.1",
    "@storybook/addon-a11y": "^10.2.15",
    "@storybook/addon-docs": "^10.2.15",
    "@storybook/addon-onboarding": "^10.2.15",
    "@storybook/addon-vitest": "^10.2.15",
    "@storybook/nextjs-vite": "^10.2.15",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/browser": "^3.2.3",
    "@vitest/coverage-v8": "^3.2.3",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "eslint-plugin-storybook": "^10.2.15",
    "playwright": "^1.53.0",
    "storybook": "^10.2.15",
    "typescript": "^5",
    "vitest": "^3.2.3"
  }
}
